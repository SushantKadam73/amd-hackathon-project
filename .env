# GRC Platform - Environment Configuration
# Copy this file and rename to .env, then fill in your values

# Environment: "development" or "production"
GRC_ENV=development

# PostgreSQL Connection
DATABASE_URL=postgresql://grc_user:grc_pass@localhost:5432/grc_dev

# OpenRouter API Key (Dev environment - get free tier key from https://openrouter.ai)
OPENROUTER_API_KEY=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


# Ollama Server URL (Production environment - local LLM serving)
OLLAMA_BASE_URL=http://localhost:11434

# Feature Flags
ENABLE_AI_CHAT=true
ENABLE_AUTO_MAPPING=true
ENABLE_MOCK_DATA=true
